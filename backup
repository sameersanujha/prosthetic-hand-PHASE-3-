#include <WiFi.h>
#include <WebServer.h>
#if defined(ESP32)
#include <ESP32Servo.h>
#else
#include <Servo.h>
#endif

#include <Wire.h>

// ================= SERVO PINS =================
#define NUM_FINGER_SERVOS 5
int servoPins[NUM_FINGER_SERVOS] = {13, 12, 14, 27, 26};
#define WRIST_SERVO_PIN 25

Servo fingerServos[NUM_FINGER_SERVOS];
Servo wristServo;

// 🔥 SMOOTHING ARRAYS
int currentAngles[NUM_FINGER_SERVOS] = {0};
int targetAngles[NUM_FINGER_SERVOS] = {0};
const int STEP = 5;   // speed (3–8 ideal)

// ================= WIFI =================
const char* ssid = "DESKTOP-ODA0D4N 5659";
const char* password = "588p21M1";

WebServer server(80);

// ================= APP COMM =================
String command = "none";
String currentGesture = "";
bool appMode = false;

// ================= EMG PARAMETERS =================
#define WINDOW_DURATION 200
#define NUM_SAMPLES 100
#define SAMPLE_RATE 500
#define BAUD_RATE 9600
#define INPUT_PIN 34
#define BUFFER_SIZE 128
#define EMG_MIN 2
#define EMG_MAX 10

float emgBuffer[NUM_SAMPLES];
unsigned long sampleInterval;

int circular_buffer[BUFFER_SIZE] = {0};
int data_index = 0;
int sum = 0;

int sampleCount = 0;

float Q = 0.006, R = 1, x = 0, P = 1, K = 0;

// ================= MODES =================
bool onMode = false;
bool gestureMode = false;
bool grabMode = false;

unsigned long grabStartTime = 0;
bool grabTimerActive = false;

// ================= ROUTES =================
void setupRoutes()
{
  server.on("/gesture", []() {
    if(server.hasArg("name"))
    {
      currentGesture = server.arg("name");
      Serial.println("Gesture: " + currentGesture);
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/status", []() {
    server.send(200, "text/plain", command);
    Serial.println("Status sent: " + command);
    
  });
}

// ================= EMG =================
int getEnvelop(int abs_emg)
{
  sum -= circular_buffer[data_index];
  sum += abs_emg;

  circular_buffer[data_index] = abs_emg;
  data_index = (data_index + 1) % BUFFER_SIZE;

  return (sum / BUFFER_SIZE) * 2;
}

float EMGFilter(float input)
{
  float output = input;

  {
    static float z1, z2;
    float x = output - 0.05159732*z1 - 0.36347401*z2;
    output = 0.01856301*x + 0.03712602*z1 + 0.01856301*z2;
    z2 = z1; z1 = x;
  }

  {
    static float z1, z2;
    float x = output + 0.53945795*z1 - 0.39764934*z2;
    output = x - 2*z1 + z2;
    z2 = z1; z1 = x;
  }

  {
    static float z1, z2;
    float x = output - 0.47319594*z1 - 0.70744137*z2;
    output = x + 2*z1 + z2;
    z2 = z1; z1 = x;
  }

  {
    static float z1, z2;
    float x = output + 1.00211112*z1 - 0.74520226*z2;
    output = x - 2*z1 + z2;
    z2 = z1; z1 = x;
  }

  return output;
}

// ================= SMOOTH SERVO UPDATE =================
void updateServosSmooth()
{
  for(int i=0;i<NUM_FINGER_SERVOS;i++)
  {
    if(currentAngles[i] < targetAngles[i])
      currentAngles[i] = min(currentAngles[i] + STEP, targetAngles[i]);
    else if(currentAngles[i] > targetAngles[i])
      currentAngles[i] = max(currentAngles[i] - STEP, targetAngles[i]);

    fingerServos[i].write(currentAngles[i]);
  }
}

// ================= APP GESTURES =================
void handleAppGestures()
{
  if(currentGesture == "") return;

  if(currentGesture == "open")
  {
    for(int i=0;i<NUM_FINGER_SERVOS;i++)
      targetAngles[i] = 0;
  }
  else if(currentGesture == "close")
  {
    for(int i=0;i<NUM_FINGER_SERVOS;i++)
      targetAngles[i] = 180;
  }
  else if(currentGesture == "point")
  {
    targetAngles[0] = 0;
    targetAngles[1] = 0;
    for(int i=2;i<NUM_FINGER_SERVOS;i++)
      targetAngles[i] = 180;
  }

  currentGesture = "";  // execute once
}

// ================= SETUP =================
void setup()
{
  Serial.begin(BAUD_RATE);

  WiFi.begin(ssid, password);
  Serial.print("Connecting");

  while (WiFi.status() != WL_CONNECTED)
  {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nConnected!");
  Serial.print("ESP IP: ");
  Serial.println(WiFi.localIP());

  setupRoutes();
  server.begin();

  Wire.begin();

  for(int i = 0; i < NUM_FINGER_SERVOS; i++)
  {
    fingerServos[i].attach(servoPins[i]);
    fingerServos[i].write(0);
    currentAngles[i] = 0;
    targetAngles[i] = 0;
  }

  wristServo.attach(WRIST_SERVO_PIN);
  wristServo.write(90);

  sampleInterval = WINDOW_DURATION / NUM_SAMPLES;
}

// ================= LOOP =================
void loop()
{
  server.handleClient();

  handleEMG();           // 🔥 ALWAYS RUN

  if(appMode)
    handleAppGestures();

  updateServosSmooth();
}
// ================= EMG HANDLER =================
void handleEMG()
{
  static unsigned long pastMicros = 0;
  unsigned long nowMicros = micros();
  unsigned long interval = nowMicros - pastMicros;
  pastMicros = nowMicros;

  static long timer = 0;
  timer -= interval;

  if(timer < 0)
  {
    timer += 1000000 / SAMPLE_RATE;

    int sensor_value = analogRead(INPUT_PIN);
    float signal = EMGFilter(sensor_value);
    int envelop = getEnvelop(abs(signal));

    int servo_position = map(envelop, EMG_MIN, EMG_MAX, 0, 180);

    float x_pred = x;
    float P_pred = P + Q;

    K = P_pred / (P_pred + R);
    x = x_pred + K * (servo_position - x_pred);
    P = (1 - K) * P_pred;

    int meanEMG = x;

    if(sampleCount < NUM_SAMPLES)
      emgBuffer[sampleCount++] = meanEMG;

    static bool muscleActive = false;

    if(sampleCount >= NUM_SAMPLES)
    {
      float windowSum = 0;
      for(int i = 0; i < NUM_SAMPLES; i++)
        windowSum += emgBuffer[i];

      float windowMean = windowSum / NUM_SAMPLES;

      float controlValue = (gestureMode || grabMode) ? meanEMG : windowMean;

      const int TRANSITION_THRESHOLD = 2400;
      const int GRAB_LOW = 1000;
      const int GRAB_HIGH = 1300;

      Serial.println(controlValue);

      if(!muscleActive && controlValue >= TRANSITION_THRESHOLD)
      {
        muscleActive = true;

        if(!onMode)
        {
          Serial.println("ON MODE");
          onMode = true;
          gestureMode = false;
          grabMode = false;
        }
        else if(grabMode)
        {
          Serial.println("OBJECT PLACED");
          grabMode = false;

          for(int i=0;i<NUM_FINGER_SERVOS;i++)
            targetAngles[i] = 0;

          onMode = false;
          gestureMode = false;
        }
        else if(!gestureMode)
        {
          Serial.println("GESTURE MODE");
          gestureMode = true;
          command = "on";
          appMode = true;
        }
        else
        {
          Serial.println("OFF");
          onMode = false;
          gestureMode = false;
          grabMode = false;
          command = "off";
          appMode = false;
          return;
        }
      }

      if(muscleActive && controlValue < TRANSITION_THRESHOLD)
        muscleActive = false;

      if(onMode && !gestureMode && !grabMode &&
         windowMean >= GRAB_LOW && windowMean <= GRAB_HIGH)
      {
        if(!grabTimerActive)
        {
          grabTimerActive = true;
          grabStartTime = millis();
        }

        if(millis() - grabStartTime >= 300)
        {
          Serial.println("GRAB MODE ACTIVATED");
          grabMode = true;

          for(int i=0;i<NUM_FINGER_SERVOS;i++)
            targetAngles[i] = 180;

          grabTimerActive = false;
        }
      }
      else
      {
        grabTimerActive = false;
      }

      sampleCount = 0;
    }
  }
}